# =============================================================================
# ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no Git!
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# Obtenha em: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# JWT Secret - Gere um valor aleatório seguro (ex: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# OAuth Configuration (se usar login social)
OAUTH_SERVER_URL="https://api.manus.im"
VITE_OAUTH_PORTAL_URL="https://portal.manus.im"

# Owner Configuration
OWNER_NAME="Seu Nome"
OWNER_OPEN_ID="seu-email@example.com"

# -----------------------------------------------------------------------------
# AWS S3 (Armazenamento de Arquivos)
# -----------------------------------------------------------------------------
# Obtenha em: AWS Console > IAM > Users > Security credentials
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-bucket-name"

# -----------------------------------------------------------------------------
# STRIPE (Pagamentos)
# -----------------------------------------------------------------------------
# Obtenha em: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# -----------------------------------------------------------------------------
# RESEND (Envio de Emails)
# -----------------------------------------------------------------------------
# Obtenha em: Resend Dashboard > API Keys
RESEND_API_KEY="re_your_resend_api_key"

# -----------------------------------------------------------------------------
# ANALYTICS (Opcional)
# -----------------------------------------------------------------------------
VITE_ANALYTICS_WEBSITE_ID="your-analytics-id"
VITE_ANALYTICS_ENDPOINT="https://your-analytics-endpoint.com"

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
VITE_APP_ID="louvamais"
VITE_APP_TITLE="LouvaMais"
VITE_APP_LOGO="/logo.svg"

# Forge API (se necessário)
BUILT_IN_FORGE_API_KEY="your-forge-api-key"
BUILT_IN_FORGE_API_URL="https://api.forge.com"
VITE_FRONTEND_FORGE_API_KEY="your-frontend-forge-key"
VITE_FRONTEND_FORGE_API_URL="https://api.forge.com"

# -----------------------------------------------------------------------------
# PRODUCTION URL
# -----------------------------------------------------------------------------
# URL do seu site em produção (para OAuth callbacks, emails, etc)
PRODUCTION_URL="https://seu-dominio.com"
